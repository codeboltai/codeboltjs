    },
    {
      "role": "user",
      "content": [
        {
          "type": "text",
          "text": "--- End of previous conversation history ---\n\nThe above messages are from a previous conversation. Any incomplete tool calls have been marked as not executed\n...[truncated 10 chars for context budget]"
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "text",
          "text": "This is the CodeBolt AI Agent. Setting up context for our chat.\nToday's date is Thursday, 9 July 2026 (formatted according to the user's locale).\nOperating \n...[truncated 300 chars for context budget]"
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "text",
          "text": "hello",
          "cache_control": {
            "type": "ephemeral"
