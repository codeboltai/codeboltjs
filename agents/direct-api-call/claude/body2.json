    {
      "role": "user",
      "content": [
        {
          "type": "text",
          "text": "hi"
        }
      ]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "text",
          "text": "Hi! How can I help you today? I have access to file operations, terminal commands, git, code search, and more within your CodeBolt environment. What would you like to work on?"
