{
  "name": "@codebolt/client-cli",
  "version": "0.1.4",
  "description": "CLI client for CodeBolt server using the client SDK",
  "main": "dist/index.js",
  "bin": {
    "codebolt-client": "bin/codebolt-client"
  },
  "files": [
    "dist",
    "bin",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "npm run build:deps && webpack --config webpack.config.js",
    "build:deps": "npm --prefix ../../CodeBolt/packages/types run build --if-present && npm --prefix ../../CodeBolt/sdks/clientsdk run build",
    "build:local": "webpack --config webpack.config.js",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@codebolt/client-sdk": "file:../../CodeBolt/sdks/clientsdk",
    "@codebolt/types": "file:../../CodeBolt/packages/types",
    "commander": "^12.0.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.17.27",
    "@types/ws": "^8.5.12",
    "ts-loader": "^9.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "ws": "^8.17.0"
  }
}
