{
  "name": "@codebolt/local-threadpool-worktree-provider",
  "version": "1.1.6",
  "description": "Generic local threadpool environment provider for CodeBolt",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "start-provider.js"
  ],
  "scripts": {
    "build": "npm run clean && node esbuild.config.js && tsc --emitDeclarationOnly",
    "start": "node start-provider.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "test:local": "NODE_ENV=test npx ts-node --esm test-local.ts",
    "test:interactive": "NODE_ENV=test npx ts-node --esm test-local.ts interactive",
    "test:server": "NODE_ENV=test npx ts-node --esm test-local.ts server",
    "test:full": "NODE_ENV=test npx ts-node --esm test-local.ts full",
    "test:startup": "NODE_ENV=test npx ts-node --esm test-startup-checks.ts"
  },
  "keywords": [
    "codebolt",
    "threadpool",
    "provider",
    "local",
    "environment"
  ],
  "author": "CodeBolt",
  "license": "MIT",
  "dependencies": {
    "@codebolt/codeboltjs": "latest",
    "@codebolt/provider": "file:../../packages/provider",
    "@codebolt/types": "^5.1.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}