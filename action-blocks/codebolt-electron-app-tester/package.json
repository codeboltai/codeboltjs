{
  "name": "codebolt-electron-app-tester",
  "private": true,
  "version": "1.0.0",
  "description": "A CodeBolt ActionBlock that runs npm i, npm run setup, and npm start, then launches an agentic loop to test a feature specified by the main agent.",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "npx webpack",
    "dev": "npx tsx src/index.ts",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "codebolt",
    "actionblock",
    "testing",
    "electron",
    "verification",
    "mini-agent"
  ],
  "author": "ravi",
  "license": "MIT",
  "dependencies": {
    "@codebolt/codeboltjs": "file:/Users/ravirawat/Documents/codeboltai/AiEditor/CodeBolt/sdks/codeboltjs",
    "@codebolt/agent": "file:/Users/ravirawat/Documents/codeboltai/AiEditor/CodeBolt/sdks/agent",
    "@codebolt/types": "file:../../../packages/types",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^12.0.2",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "process": "^0.11.10",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.103.0",
    "webpack-cli": "^5.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "tsx": "^4.7.0"
  },
  "pnpm": {
    "overrides": {
      "@codebolt/types": "file:../../../packages/types",
      "@codebolt/codeboltjs>@codebolt/types": "file:../../../packages/types",
      "@codebolt/agent>@codebolt/types": "file:../../../packages/types"
    }
  },
  "files": [
    "dist/**/*"
  ]
}
