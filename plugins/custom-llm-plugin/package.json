{
  "name": "@codebolt/custom-llm-plugin",
  "version": "1.0.0",
  "description": "Example plugin that registers a custom LLM provider via the plugin SDK",
  "main": "dist/index.js",
  "scripts": {
    "build": "node build.mjs",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "tsc --watch"
  },
  "codebolt": {
    "plugin": {
      "type": "llmProvider",
      "triggers": [
        {
          "type": "startup"
        }
      ]
    }
  },
  "dependencies": {
    "@codebolt/plugin-sdk": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
