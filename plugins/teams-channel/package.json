{
  "name": "teams-channel",
  "version": "1.0.0",
  "displayName": "Microsoft Teams Channel",
  "description": "Microsoft Teams bot integration for CodeBolt — receives messages from Teams and routes them to agents via the gateway",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codebolt/plugin-sdk": "*",
    "botbuilder": "^4.22.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/express": "^4.17.21"
  },
  "codebolt": {
    "plugin": {
      "type": "channel",
      "triggers": [{ "type": "manual" }],
      "ui": { "path": "./ui/default/index.html" }
    }
  }
}
