{
  "name": "whatsapp-channel",
  "version": "1.0.0",
  "displayName": "WhatsApp Channel",
  "description": "WhatsApp integration for CodeBolt — receives messages from WhatsApp and routes them to agents via the gateway",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codebolt/plugin-sdk": "*",
    "@whiskeysockets/baileys": "^6.7.16",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "codebolt": {
    "plugin": {
      "type": "channel",
      "triggers": [{ "type": "manual" }],
      "ui": { "path": "./ui/default/index.html" }
    }
  }
}
